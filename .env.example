# Copia este archivo a .env y edita las rutas
# cp .env.example .env

# Ruta a la carpeta raíz del dataset (contiene user*/...)
SANN_DATA_ROOT=/ruta/a/tu/dataset

# Ruta al archivo SQLite (se crea al importar; por defecto: data/sann.db)
# SANN_DB_PATH=/ruta/personalizada/sann.db

# IPs del atacante para clasificación sensor_packet (separadas por coma)
# Si no se define, usa los defaults del dataset P003.
# Para P032 u otros datasets, define las IPs del atacante aquí:
# SANN_ATTACKER_IPS=10.0.0.1,10.0.0.2

# Orígenes permitidos para CORS (separados por coma)
# SANN_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
