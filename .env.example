# Copia este archivo a .env y edita las rutas para tu máquina
# cp .env.example .env

# Ruta a la carpeta raíz del dataset (la que contiene user0003/, user2003/, etc.)
GODEYE_DATA_ROOT=/ruta/a/tu/dataset

# Ruta al archivo de base de datos SQLite (se crea automáticamente al importar)
# Por defecto: data/godeye_v2.db relativo al repo — normalmente no necesitas cambiar esto
# GODEYE_DB_PATH=/ruta/personalizada/godeye_v2.db
